{
  "name": "@stoachain/dalos-crypto",
  "version": "4.0.2",
  "description": "DALOS Cryptography — Ouronet's custom 1606-bit Twisted Edwards curve, Schnorr signatures, bitmap key generation. TypeScript port of the Genesis Go reference.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gen1": {
      "types": "./dist/gen1/index.d.ts",
      "import": "./dist/gen1/index.js"
    },
    "./dalos-blake3": {
      "types": "./dist/dalos-blake3/index.d.ts",
      "import": "./dist/dalos-blake3/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js"
    },
    "./historical": {
      "types": "./dist/historical/index.d.ts",
      "import": "./dist/historical/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "clean": "rimraf dist",
    "docs:check": "node scripts/check-readme.mjs",
    "prepack": "node -e \"require('fs').copyFileSync(require('path').resolve('..','CHANGELOG.md'),'CHANGELOG.md')\"",
    "postpack": "node -e \"try { require('fs').unlinkSync('CHANGELOG.md'); } catch (e) {}\""
  },
  "keywords": [
    "cryptography",
    "dalos",
    "ouronet",
    "stoachain",
    "twisted-edwards",
    "schnorr",
    "elliptic-curve",
    "blockchain"
  ],
  "author": "Kjrekntolopon (AncientHoldings GmbH) <Kjrekntolopon@ancientholdings.eu>",
  "license": "SEE LICENSE IN ../LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/StoaChain/DALOS_Crypto.git",
    "directory": "ts"
  },
  "homepage": "https://github.com/StoaChain/DALOS_Crypto#readme",
  "bugs": {
    "url": "https://github.com/StoaChain/DALOS_Crypto/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "3.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  }
}
